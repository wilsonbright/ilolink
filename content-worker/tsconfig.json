{
  // Standalone Worker tsconfig — no Next, no "@/" alias. The "../../lib/*"
  // imports resolve as ordinary relative paths, and the shared crypto/csp/type
  // modules pull in cleanly because they depend only on Web platform APIs.
  // Runtime globals (KVNamespace, R2Bucket, Response, crypto, ...) come from the
  // generated runtime types in ../cloudflare-env.d.ts.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": [],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "../cloudflare-env.d.ts"]
}
